# App mode
DATA_MODE=seed
NODE_ENV=development

# Public app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only secrets. Never expose these with NEXT_PUBLIC_ prefixes.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Model routing
MODEL_PROVIDER=mock
MODEL_SUMMARY=mock-summary
MODEL_EXTRACTION=mock-extraction
MODEL_EMBEDDINGS=mock-embeddings
# Example live OpenAI summary model when MODEL_PROVIDER=openai:
# MODEL_SUMMARY=gpt-4o-mini

# Job security. Public readers must never trigger these jobs.
# Required only before enabling private manual/scheduled ingestion.
INGESTION_JOB_TOKEN=
ANALYSIS_JOB_TOKEN=
ENABLE_JOB_ENDPOINTS=false

# Cost and volume controls
MAX_EVENTS_PER_RUN=5
MAX_ARTICLES_PER_EVENT=40
MAX_DISCOVERY_QUERIES_PER_RUN=8
MAX_ARTICLES_PER_DISCOVERY_QUERY=15
MAX_ARTICLES_PER_INGEST_RUN=80
ENABLE_RSS_DISCOVERY=true
ENABLE_GDELT_DISCOVERY=true
MAX_AGGREGATOR_FEED_ITEMS_PER_RUN=60
MAX_EVIDENCE_ARTICLES_PER_RUN=25
MAX_EVIDENCE_CHARS_PER_ARTICLE=900
MAX_EVIDENCE_CHARS_PER_EVENT=18000
MIN_ARTICLES_PER_CLUSTER=2
MIN_SOURCES_PER_CLUSTER=2
CLUSTER_SIMILARITY_THRESHOLD=0.3
MAX_LLM_CALLS_PER_RUN=25
MAX_LLM_ESTIMATED_COST_USD_PER_RUN=2
LLM_ESTIMATED_COST_USD_PER_CALL=0
DISABLE_LIVE_ANALYSIS=true
